---
import { render } from "astro:content";
import { site } from "../data/site";
import { formatDate, normalizeTaxonomy } from "../lib/format";
import { postPath, type BlogPost } from "../lib/posts";

type Props = {
  posts: BlogPost[];
};

const { posts } = Astro.props;
const renderedPosts = await Promise.all(
  posts.map(async (post) => {
    const { Content } = await render(post);
    return {
      post,
      Content,
      updatedIsLater: post.data.updated && post.data.updated > post.data.published
    };
  })
);
---

<div class="feed">
  {
    renderedPosts.map(({ post, Content, updatedIsLater }) => (
      <article class="feed-post" id={post.data.slug}>
        <header class="feed-post__header">
          <p class="eyebrow">
            <a href={`/categories/${normalizeTaxonomy(post.data.category)}/`}>{post.data.category}</a>
          </p>
          <h2>
            <a href={postPath(post)}>{post.data.title}</a>
          </h2>
          <p class="dek">{post.data.description}</p>
          <div class="post-meta">
            <time datetime={post.data.published.toISOString()}>{formatDate(post.data.published)}</time>
            {updatedIsLater && (
              <>
                <span aria-hidden="true">/</span>
                <span>Updated {formatDate(post.data.updated!)}</span>
              </>
            )}
          </div>
          {post.data.tags.length > 0 && (
            <ul class="tag-list" aria-label={`Tags for ${post.data.title}`}>
              {post.data.tags.map((tag) => (
                <li>
                  <a href={`/tags/${normalizeTaxonomy(tag)}/`}>{tag}</a>
                </li>
              ))}
            </ul>
          )}
          {post.data.aiAssisted && (
            <aside class="editorial-note" aria-label="Editorial disclosure">
              <h3>Editorial Note</h3>
              <p>{post.data.aiDisclosure ?? site.aiDisclosure}</p>
            </aside>
          )}
          {post.data.heroImage && (
            <figure class="hero-image">
              <img src={post.data.heroImage} alt={post.data.heroAlt ?? ""} />
              {post.data.heroCaption && <figcaption>{post.data.heroCaption}</figcaption>}
            </figure>
          )}
        </header>
        <div class="article-content">
          <Content />
        </div>
        <p class="post-permalink">
          <a href={postPath(post)}>Permalink</a>
        </p>
      </article>
    ))
  }
</div>
