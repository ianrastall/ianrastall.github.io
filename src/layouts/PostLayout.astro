---
import { render } from "astro:content";
import { site } from "../data/site";
import { formatDate, normalizeTaxonomy } from "../lib/format";
import { postPath, type BlogPost } from "../lib/posts";
import BaseLayout from "./BaseLayout.astro";

type Props = {
  post: BlogPost;
};

const { post } = Astro.props;
const { Content } = await render(post);
const updatedIsLater = post.data.updated && post.data.updated > post.data.published;
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonicalPath={postPath(post)}
>
  <article class="post" data-pagefind-body>
    <header class="post-header">
      <p class="eyebrow">
        <a href={`/categories/${normalizeTaxonomy(post.data.category)}/`}>{post.data.category}</a>
      </p>
      <h1 data-pagefind-meta="title">{post.data.title}</h1>
      <p class="dek">{post.data.description}</p>
      <div class="post-meta">
        <time datetime={post.data.published.toISOString()}>{formatDate(post.data.published)}</time>
        {
          updatedIsLater && (
            <>
              <span aria-hidden="true">/</span>
              <span>Updated {formatDate(post.data.updated!)}</span>
            </>
          )
        }
      </div>
      {
        post.data.tags.length > 0 && (
          <ul class="tag-list" aria-label="Post tags">
            {post.data.tags.map((tag) => (
              <li>
                <a href={`/tags/${normalizeTaxonomy(tag)}/`}>{tag}</a>
              </li>
            ))}
          </ul>
        )
      }
      {
        post.data.aiAssisted && (
          <aside class="editorial-note" aria-label="Editorial disclosure">
            <h2>Editorial Note</h2>
            <p>{post.data.aiDisclosure ?? site.aiDisclosure}</p>
          </aside>
        )
      }
      {
        post.data.heroImage && (
          <figure class="hero-image">
            <img src={post.data.heroImage} alt="" />
          </figure>
        )
      }
    </header>
    <div class="article-content">
      <Content />
    </div>
  </article>
</BaseLayout>
