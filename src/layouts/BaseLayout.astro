---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { SITE } from "../lib/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalPath?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
  image,
  canonicalPath = Astro.url.pathname
} = Astro.props;

const pageTitle = title === SITE.title ? SITE.title : `${title} | ${SITE.title}`;
const canonicalUrl = new URL(canonicalPath, Astro.site ?? SITE.url).toString();
const imageUrl = image ? new URL(image, Astro.site ?? SITE.url).toString() : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} RSS`} href="/rss.xml" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta name="twitter:card" content={imageUrl ? "summary_large_image" : "summary"} />
    <meta name="theme-color" content="#111513" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f7f3ed" media="(prefers-color-scheme: light)" />
  </head>
  <body>
    <div class="site-shell">
      <SiteHeader />
      <main id="main-content">
        <slot />
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
