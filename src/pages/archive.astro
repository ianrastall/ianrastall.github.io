---
import PostList from "../components/PostList.astro";
import { getPublishedPosts, type BlogPost } from "../lib/posts";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = await getPublishedPosts();
const postsByYear = posts.reduce((groups, post) => {
  const year = post.data.published.getFullYear().toString();
  const yearPosts = groups.get(year) ?? [];
  yearPosts.push(post);
  groups.set(year, yearPosts);
  return groups;
}, new Map<string, BlogPost[]>());
---

<BaseLayout title="Archive" description="Published Fooliosity posts by date." canonicalPath="/archive/" current="archive">
  <section class="page-heading">
    <p class="eyebrow">Archive</p>
    <h1>Archive</h1>
  </section>

  {
    postsByYear.size > 0 ? (
      [...postsByYear.entries()].map(([year, yearPosts]) => (
        <section class="content-section" aria-labelledby={`year-${year}`}>
          <div class="section-heading">
            <h2 id={`year-${year}`}>{year}</h2>
          </div>
          <PostList posts={yearPosts} />
        </section>
      ))
    ) : (
      <p class="empty-state">No published posts yet.</p>
    )
  }
</BaseLayout>
