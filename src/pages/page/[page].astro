---
import FeedPagination from "../../components/FeedPagination.astro";
import PostFeed from "../../components/PostFeed.astro";
import { getFeedPage, pagePath, POSTS_PER_PAGE } from "../../lib/pagination";
import { getPublishedPosts } from "../../lib/posts";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => {
    const page = index + 2;
    return {
      params: { page: String(page) },
      props: { feed: getFeedPage(posts, page) }
    };
  });
}

const { feed } = Astro.props;
---

<BaseLayout
  title={`Posts Page ${feed.currentPage}`}
  description={`Older Fooliosity posts, page ${feed.currentPage}.`}
  canonicalPath={pagePath(feed.currentPage)}
>
  <section class="page-heading">
    <p class="eyebrow">Older Posts</p>
    <h1>Page {feed.currentPage}</h1>
  </section>
  <PostFeed posts={feed.posts} />
  <FeedPagination currentPage={feed.currentPage} totalPages={feed.totalPages} />
</BaseLayout>
