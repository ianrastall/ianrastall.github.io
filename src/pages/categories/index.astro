---
import { getPublishedPosts, groupByCategory } from "../../lib/posts";
import BaseLayout from "../../layouts/BaseLayout.astro";

const groups = groupByCategory(await getPublishedPosts());
---

<BaseLayout title="Categories" description="Browse Fooliosity posts by category." canonicalPath="/categories/" current="categories">
  <section class="page-heading">
    <p class="eyebrow">Categories</p>
    <h1>Categories</h1>
  </section>
  {
    groups.length > 0 ? (
      <ul class="taxonomy-index">
        {groups.map((group) => (
          <li>
            <a href={`/categories/${group.slug}/`}>
              <span>{group.name}</span>
              <small>{group.posts.length}</small>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty-state">No categories yet.</p>
    )
  }
</BaseLayout>
