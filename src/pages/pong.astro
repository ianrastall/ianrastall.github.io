---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pong">
  <main class="shell tool-shell">
    <div class="tool-bar">
      <div class="tool-title">
        <h1>Pong</h1>
        <p>A simple Pong-like game with top and bottom paddles. Use the left and right arrow keys to move your paddle. First to 5 points wins.</p>
      </div>
    </div>

    <div class="two-column" style="display: grid; grid-template-columns: 1fr; max-width: 800px; margin: 0 auto;">
      <div class="panel d-flex flex-column align-items-center" style="display: flex; flex-direction: column; align-items: center;">
        <canvas id="pongCanvas" width="750" height="500" style="max-width: 100%; height: auto; border: 1px solid var(--border); border-radius: 4px;"></canvas>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const canvas = document.getElementById('pongCanvas') as HTMLCanvasElement;
        if (!canvas) return;
        const context = canvas.getContext('2d');
        if (!context) return;
        
        // Grab accent color dynamically during the loop so theme changes are reflected
        function getAccentColor() {
            return getComputedStyle(document.documentElement).getPropertyValue('--accent').trim() || '#0f766e';
        }

        let gameRunning = true;

        // Game objects
        const player = {
            x: canvas.width / 2 - 50,
            y: canvas.height - 20,
            width: 100,
            height: 10,
            score: 0,
            dx: 0
        };

        const computer = {
            x: canvas.width / 2 - 50,
            y: 10,
            width: 100,
            height: 10,
            score: 0
        };

        const ball = {
            x: canvas.width / 2,
            y: canvas.height / 2,
            radius: 8,
            speed: 3, 
            dx: 3,
            dy: -3
        };

        // Draw functions
        function drawPaddle(x: number, y: number, w: number, h: number, color: string) {
            context!.fillStyle = color;
            context!.fillRect(x, y, w, h);
        }

        function drawBall(x: number, y: number, r: number, color: string) {
            context!.fillStyle = color;
            context!.beginPath();
            context!.arc(x, y, r, 0, Math.PI * 2, false);
            context!.closePath();
            context!.fill();
        }

        function drawText(text: string | number, x: number, y: number, color: string) {
            context!.fillStyle = color;
            context!.font = '30px "Inter", sans-serif';
            context!.fillText(String(text), x, y);
        }

        function drawCenterLine(color: string) {
            context!.beginPath();
            context!.setLineDash([10, 10]);
            context!.moveTo(0, canvas.height / 2);
            context!.lineTo(canvas.width, canvas.height / 2);
            context!.strokeStyle = color;
            context!.stroke();
            context!.setLineDash([]);
        }

        // Game Logic
        function update() {
            if (!gameRunning) return;

            // Move player paddle
            player.x += player.dx;
            if (player.x < 0) player.x = 0;
            if (player.x + player.width > canvas.width) player.x = canvas.width - player.width;

            // AI for computer paddle
            const computerLevel = 0.08; 
            computer.x += (ball.x - (computer.x + computer.width / 2)) * computerLevel;
             if (computer.x < 0) computer.x = 0;
            if (computer.x + computer.width > canvas.width) computer.x = canvas.width - computer.width;

            // Move ball
            ball.x += ball.dx;
            ball.y += ball.dy;

            // Ball collision with left/right walls
            if (ball.x + ball.radius > canvas.width || ball.x - ball.radius < 0) {
                ball.dx *= -1;
            }

            // Ball collision detection with paddles
            if (ball.y - ball.radius < (computer.y + computer.height) && ball.x > computer.x && ball.x < computer.x + computer.width) {
                 ball.dy = ball.speed;
            }

            if (ball.y + ball.radius > player.y && ball.x > player.x && ball.x < player.x + player.width) {
                ball.dy = -ball.speed;
            }

            // Score points
            if (ball.y + ball.radius > canvas.height) {
                computer.score++;
                checkWin();
                resetBall();
            }

            if (ball.y - ball.radius < 0) {
                player.score++;
                checkWin();
                resetBall();
            }
        }
        
        function checkWin() {
            let winner = null;
            if (player.score >= 5) winner = "Player";
            if (computer.score >= 5) winner = "Computer";

            if (winner) {
                gameRunning = false;
                setTimeout(() => {
                    alert(`${winner} wins!`);
                    player.score = 0;
                    computer.score = 0;
                    gameRunning = true;
                    resetBall();
                }, 100);
            }
        }

        function resetBall() {
            ball.x = computer.x + computer.width / 2;
            ball.y = computer.y + computer.height + ball.radius + 5;
            ball.dx = (Math.random() > 0.5 ? 1 : -1) * ball.speed / 2;
            ball.dy = ball.speed;
        }

        function render() {
            const isDark = document.documentElement.dataset.theme === 'dark';
            const bgColor = isDark ? '#171c24' : '#ffffff';
            const textColor = isDark ? '#edf2f7' : '#172033';
            const lineColor = isDark ? '#30394a' : '#d7dee8';
            const accent = getAccentColor();

            // Clear canvas
            context!.fillStyle = bgColor;
            context!.fillRect(0, 0, canvas.width, canvas.height);

            drawCenterLine(lineColor);

            // Draw scores
            drawText(player.score, 20, canvas.height - 20, textColor);
            drawText(computer.score, 20, 40, textColor);

            // Draw paddles
            drawPaddle(player.x, player.y, player.width, player.height, accent);
            drawPaddle(computer.x, computer.y, computer.width, computer.height, accent);

            // Draw ball
            drawBall(ball.x, ball.y, ball.radius, accent);
        }

        function gameLoop() {
            update();
            render();
            requestAnimationFrame(gameLoop);
        }

        // Keyboard controls
        document.addEventListener('keydown', function(event) {
            // Only capture arrow keys to prevent scrolling when playing
            if (event.key === "ArrowLeft" || event.key === "ArrowRight") {
                event.preventDefault();
            }
            switch(event.key) {
                case "ArrowLeft":
                    player.dx = -6;
                    break;
                case "ArrowRight":
                    player.dx = 6;
                    break;
            }
        });

        document.addEventListener('keyup', function(event) {
             switch(event.key) {
                case "ArrowLeft":
                case "ArrowRight":
                    player.dx = 0;
                    break;
            }
        });

        // Initial ball position
        resetBall();
        gameLoop();
    });
</script>
