---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Search" description="Search published Fooliosity posts." canonicalPath="/search/" current="search">
  <section class="page-heading">
    <p class="eyebrow">Search</p>
    <h1>Search</h1>
  </section>
  <section class="search-panel" aria-label="Site search">
    <div id="search"></div>
  </section>
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script type="module" is:inline>
    const target = document.querySelector("#search");

    try {
      const pagefind = await import("/pagefind/pagefind-ui.js");
      new pagefind.PagefindUI({
        element: "#search",
        showImages: false,
        showSubResults: true,
        resetStyles: false
      });
    } catch {
      if (target) {
        target.innerHTML =
          '<p class="empty-state">The search index is generated by <code>npm run build</code>.</p>';
      }
    }
  </script>
</BaseLayout>
