---
import PostList from "../components/PostList.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getFeaturedPosts, getPublicPosts, getRecentPosts } from "../lib/posts";
import { SITE } from "../lib/site";

const posts = await getPublicPosts();
const featuredPosts = getFeaturedPosts(posts);
const recentPosts = getRecentPosts(posts, 6);
---

<BaseLayout title={SITE.title} description={SITE.description} canonicalPath="/">
  <section class="home-hero">
    <div class="home-hero__copy">
      <p class="eyebrow">Public notebook and publication site</p>
      <h1>{SITE.name}</h1>
      <p>
        A static home for long-form essays, notes, analysis, and project writing.
      </p>
      <div class="hero-actions">
        <a class="button" href="/archive/">Read the archive</a>
        <a class="button button--quiet" href="/rss.xml">RSS feed</a>
      </div>
    </div>
    <img class="home-hero__mark" src="/images/site/fooliosity-mark.svg" alt="" width="180" height="180" />
  </section>

  {
    featuredPosts.length > 0 && (
      <section class="content-section" aria-labelledby="featured-posts">
        <div class="section-heading">
          <h2 id="featured-posts">Featured</h2>
        </div>
        <PostList posts={featuredPosts} />
      </section>
    )
  }

  <section class="content-section" aria-labelledby="recent-posts">
    <div class="section-heading">
      <h2 id="recent-posts">Recent Posts</h2>
      <a href="/archive/">Archive</a>
    </div>
    <PostList posts={recentPosts} />
  </section>
</BaseLayout>
