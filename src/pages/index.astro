---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Ian Rastall - Repositories">
  <main class="shell">
    <section class="hero text-center pt-5 pb-4">
      <h1>Recently Updated Repositories</h1>
      <p class="lead text-muted">
        A live snapshot of the public projects I have touched most recently.
      </p>
    </section>

    <section class="repo-grid" id="repo-grid" aria-label="Recently updated GitHub repositories" aria-live="polite">
      <article class="repo-box repo-loading">
        <h2>Loading repositories…</h2>
        <p>Fetching the most recently updated public projects from GitHub.</p>
      </article>
    </section>

    <p class="repo-error" id="repo-error" hidden>
      GitHub repository data could not be loaded right now.
      <a href="https://github.com/ianrastall" target="_blank" rel="noopener noreferrer">View all repositories on GitHub.</a>
    </p>

    <div class="repo-actions">
      <a class="button primary" href="https://github.com/ianrastall" target="_blank" rel="noopener noreferrer">
        View all repositories on GitHub
      </a>
    </div>
  </main>
</BaseLayout>

<script>
  interface GitHubRepo {
    name: string;
    description: string | null;
    html_url: string;
    language: string | null;
    pushed_at: string | null;
    stargazers_count: number;
    forks_count: number;
    private: boolean;
    archived: boolean;
    fork: boolean;
  }

  const grid = document.getElementById('repo-grid');
  const error = document.getElementById('repo-error');

  const repoEndpoint =
    'https://api.github.com/users/ianrastall/repos?type=owner&sort=pushed&direction=desc&per_page=20';

  const excludedRepos = new Set<string>([
    'ianrastall.github.io'
  ]);

  function formatDate(value: string | null): string {
    if (!value) return 'Unknown date';

    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return 'Unknown date';

    return new Intl.DateTimeFormat('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric'
    }).format(date);
  }

  function escapeHtml(value: unknown): string {
    return String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }

  function repoDescription(repo: GitHubRepo): string {
    return repo.description?.trim() || 'No repository description has been added yet.';
  }

  function repoMeta(repo: GitHubRepo): string[] {
    const parts: string[] = [];

    if (repo.language) {
      parts.push(escapeHtml(repo.language));
    }

    parts.push(`Updated ${escapeHtml(formatDate(repo.pushed_at))}`);
    parts.push(`★ ${repo.stargazers_count.toLocaleString()}`);
    parts.push(`Forks ${repo.forks_count.toLocaleString()}`);

    return parts;
  }

  function renderRepo(repo: GitHubRepo): string {
    const meta = repoMeta(repo);

    return `
      <article class="repo-box">
        <div class="repo-card-main">
          <h2>${escapeHtml(repo.name)}</h2>
          <p>${escapeHtml(repoDescription(repo))}</p>
        </div>

        <ul class="repo-meta" aria-label="Repository metadata">
          ${meta.map((item: string) => `<li>${item}</li>`).join('')}
        </ul>

        <a href="${escapeHtml(repo.html_url)}" target="_blank" rel="noopener noreferrer" class="repo-link">
          View Repository &rarr;
        </a>
      </article>
    `;
  }

  async function loadRecentRepos(): Promise<void> {
    if (!grid) return;

    try {
      const response = await fetch(repoEndpoint, {
        headers: {
          Accept: 'application/vnd.github+json'
        }
      });

      if (!response.ok) {
        throw new Error(`GitHub API returned ${response.status}`);
      }

      const repos = (await response.json()) as GitHubRepo[];

      const recentRepos = repos
        .filter((repo: GitHubRepo) => !repo.private)
        .filter((repo: GitHubRepo) => !repo.archived)
        .filter((repo: GitHubRepo) => !repo.fork)
        .filter((repo: GitHubRepo) => !excludedRepos.has(repo.name))
        .slice(0, 5);

      if (recentRepos.length === 0) {
        throw new Error('No repositories matched the display filters.');
      }

      grid.innerHTML = recentRepos.map(renderRepo).join('');
    } catch (err: unknown) {
      console.error(err);
      grid.innerHTML = '';
      if (error) error.hidden = false;
    }
  }

  loadRecentRepos();
</script>

<style>
  .repo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    padding: 2rem 0;
  }

  .repo-box {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    background-color: var(--panel);
    display: flex;
    flex-direction: column;
    min-height: 260px;
    box-shadow: var(--shadow);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .repo-box:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
  }

  .repo-card-main {
    flex: 1;
  }

  .repo-box h2 {
    margin-top: 0;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
    color: var(--text);
  }

  .repo-box p {
    color: var(--muted);
    line-height: 1.55;
    margin-bottom: 1.25rem;
  }

  .repo-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
  }

  .repo-meta li {
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--panel-muted);
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1;
    padding: 0.45rem 0.65rem;
  }

  .repo-link {
    display: inline-block;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
    align-self: flex-start;
  }

  .repo-link:hover {
    color: var(--accent-strong);
    text-decoration: underline;
  }

  .repo-loading {
    opacity: 0.75;
  }

  .repo-error {
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--panel-muted);
    color: var(--muted);
    padding: 1rem;
  }

  .repo-error a {
    color: var(--accent);
    font-weight: 700;
  }

  .repo-actions {
    display: flex;
    justify-content: center;
    padding: 0.5rem 0 3rem;
  }

  .text-center {
    text-align: center;
  }

  .text-center h1,
  .text-center p {
    margin-left: auto;
    margin-right: auto;
  }

  .pt-5 {
    padding-top: 3rem;
  }

  .pb-4 {
    padding-bottom: 1.5rem;
  }

  .lead {
    font-size: 1.08rem;
  }
</style>