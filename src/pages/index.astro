---
import ToolCard from '../components/ToolCard.astro';
import { tools } from '../data/tools';
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Fooliosity">
  <main class="shell">
    <section class="hero text-center pt-5 pb-4">
      <h1>Time Wasters</h1>
      <p class="lead text-muted">A collection of simple games and toys to pass the time.</p>
    </section>
    <section class="tool-grid" aria-label="Available tools">
      {tools.map((tool) => <ToolCard tool={tool} />)}
    </section>
  </main>
</BaseLayout>
